# ─────────────────────────────────────────────────────────────
#  CareCompanion — environment variables
#
#  Copy this file to .env.local and fill in the values:
#      cp .env.example .env.local
#
#  .env.local is git-ignored. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── AI (required for AI features) ────────────────────────────
# A free key from https://console.groq.com is enough for every AI feature:
# report summaries, health chat, symptom analysis, visit-prep questions, and
# drug-interaction checks. Every non-AI feature works without this key.
GROQ_API_KEY=

# ── Local development shortcut ───────────────────────────────
# Set to "true" to skip Google sign-in while developing locally; the app
# auto-creates a "Demo" profile. IGNORED in production builds — it can never
# disable auth on a deployed instance. NEVER set this on Vercel/production.
NEXT_PUBLIC_DEV_SKIP_AUTH=true

# ── Authentication (NextAuth + Google OAuth) ─────────────────
# Required in production. Optional locally when NEXT_PUBLIC_DEV_SKIP_AUTH=true.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=            # generate with: openssl rand -base64 32

# Google OAuth client — https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Supabase (auth SESSIONS ONLY — no health data is stored here) ──
# https://supabase.com — used solely to track authenticated sessions.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
