# ─────────────────────────────────────────────────────────────
#  CareCompanion — environment variables
#
#  Copy this file to .env.local and fill in the values:
#      cp .env.example .env.local
#
#  .env.local is git-ignored. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── AI (required for AI features) ────────────────────────────
# A free key from https://console.groq.com is enough for every AI feature:
# report summaries, health chat, symptom analysis, visit-prep questions, and
# drug-interaction checks. Every non-AI feature works without this key.
GROQ_API_KEY=

# ── Local development shortcut ───────────────────────────────
# Set to "true" to skip Google sign-in while developing locally; the app
# auto-creates a "Demo" profile. IGNORED in production builds — it can never
# disable auth on a deployed instance. NEVER set this on Vercel/production.
NEXT_PUBLIC_DEV_SKIP_AUTH=true

# ── Authentication (NextAuth + Google OAuth) ─────────────────
# Required in production. Optional locally when NEXT_PUBLIC_DEV_SKIP_AUTH=true.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=            # generate with: openssl rand -base64 32

# Google OAuth client — https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Supabase (auth SESSIONS ONLY — no health data is stored here) ──
# https://supabase.com — used solely to track authenticated sessions.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Find Care map basemap (OPTIONAL) ─────────────────────────
# A free key from https://cloud.maptiler.com gives the Find Care map nicer,
# global tiles (free tier: 100k requests/month). LEAVE BLANK to keep the
# default OpenStreetMap tiles — the map works either way. This value is exposed
# to the browser, so it MUST be domain-restricted in the MapTiler dashboard
# (Account → Keys → Allowed origins: your domain(s) + http://localhost:3000).
NEXT_PUBLIC_MAPTILER_KEY=

# ── Find Care facility coverage — Ola Maps (OPTIONAL, India only) ──
# A key from https://maps.olakrutrim.com gives deeper facility coverage for
# searches inside India (generous free tier). Server-side only — do NOT add a
# NEXT_PUBLIC_ prefix. LEAVE BLANK to use OpenStreetMap everywhere. When set,
# searches inside India use Ola first and fall back to OpenStreetMap on any
# error/timeout/empty result; searches outside India always use OpenStreetMap.
OLA_MAPS_API_KEY=
# Optional kill-switch: set to "1" to force OpenStreetMap everywhere even if the
# Ola key above is present (instant disable without removing the key).
FIND_CARE_DISABLE_OLA=
